{
  "name": "houhou",
  "version": "0.2.0",
  "description": "A lightweight TypeScript library for adding resilience policies to async functions.",
  "keywords": [
    "async",
    "circuit-breaker",
    "delay",
    "fallback",
    "fault-tolerance",
    "resilience",
    "retry",
    "timeout",
    "typescript"
  ],
  "homepage": "https://github.com/smokeeaasd/houhou#readme",
  "bugs": {
    "url": "https://github.com/smokeeaasd/houhou/issues"
  },
  "license": "MIT",
  "author": "smokeeaasd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smokeeaasd/houhou.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky || true",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.15.1"
}
